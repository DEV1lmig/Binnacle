{
  "expo": {
    "name": "Binnacle Mobile",
    "slug": "binnacle-mobile",
    "scheme": "binnacle",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Binnacle to save review cards to your photo library.",
          "savePhotosPermission": "Allow Binnacle to save review cards to your photo library."
        }
      ],
      [
        "react-native-share",
        {
          "ios": [
            "instagram",
            "instagram-stories"
          ],
          "android": [
            "com.instagram.android"
          ],
          "enableBase64ShareAndroid": true
        }
      ],
      "expo-build-properties"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "shareBaseUrl": "http://localhost:3000",
      "facebookAppId": ""
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.binnacle.mobile"
    },
    "android": {
      "package": "com.binnacle.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
